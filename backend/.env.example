OPENWEATHER_API_KEY=
GEOAPIFY_API_KEY=

# Postgres (Supabase) credentials, split into parts. The app percent-encodes
# DB_USER/DB_PASSWORD itself (urllib.parse.quote_plus, see app/database.py)
# when it builds the connection URL, so paste the password exactly as Supabase
# shows it -- special characters (@, !, $, &, etc.) are handled automatically.
# No manual re-encoding needed, including after a future password rotation.
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres

# Alternative: set DATABASE_URL directly instead of the DB_* vars above to
# override them entirely. Takes precedence when set. This is what Render/
# Railway inject automatically at deploy time (already URL-encoded by them).
# DATABASE_URL=
